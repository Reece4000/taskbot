{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "summary",
    "constraints",
    "relevant_files",
    "steps",
    "verification",
    "subagent_splits"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relevant_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "title",
          "details",
          "files",
          "parallelisable"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "parallelisable": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "subagent_splits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "files"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
