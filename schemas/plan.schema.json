{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "summary",
    "constraints",
    "relevant_files",
    "steps",
    "verification",
    "subagent_splits",
    "decomposition"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relevant_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/plan_step"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "subagent_splits": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subagent_split"
      }
    },
    "decomposition": {
      "type": "object",
      "required": [
        "should_split",
        "reason",
        "subtasks"
      ],
      "properties": {
        "should_split": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "subtasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/decomposition_subtask"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "plan_step": {
      "type": "object",
      "required": [
        "title",
        "details",
        "files",
        "parallelisable"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parallelisable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "subagent_split": {
      "type": "object",
      "required": [
        "title",
        "files"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "embedded_plan": {
      "type": "object",
      "required": [
        "summary",
        "constraints",
        "relevant_files",
        "steps",
        "verification",
        "subagent_splits"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relevant_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/plan_step"
          }
        },
        "verification": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "subagent_splits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subagent_split"
          }
        }
      },
      "additionalProperties": false
    },
    "decomposition_subtask": {
      "type": "object",
      "required": [
        "board_title",
        "title",
        "context_notes",
        "acceptance",
        "phase",
        "plan"
      ],
      "properties": {
        "board_title": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "context_notes": {
          "type": "string"
        },
        "acceptance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "phase": {
          "type": "string"
        },
        "plan": {
          "$ref": "#/$defs/embedded_plan"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
