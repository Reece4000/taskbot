{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "message",
    "questions",
    "tickets"
  ],
  "properties": {
    "message": {
      "type": "string"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tickets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ticket"
      }
    }
  },
  "$defs": {
    "ticket": {
      "type": "object",
      "required": [
        "board_title",
        "title",
        "phase",
        "context_notes",
        "file_targets",
        "acceptance",
        "complexity",
        "plan"
      ],
      "properties": {
        "board_title": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "phase": {
          "type": "string",
          "enum": [
            "ready",
            "planning"
          ]
        },
        "context_notes": {
          "type": "string"
        },
        "file_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "complexity": {
          "type": "string",
          "enum": [
            "simple",
            "complex"
          ]
        },
        "plan": {
          "anyOf": [
            {
              "$ref": "#/$defs/plan"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "plan": {
      "type": "object",
      "required": [
        "summary",
        "constraints",
        "relevant_files",
        "steps",
        "verification",
        "subagent_splits"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relevant_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/plan_step"
          }
        },
        "verification": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "subagent_splits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subagent_split"
          }
        }
      },
      "additionalProperties": false
    },
    "plan_step": {
      "type": "object",
      "required": [
        "title",
        "details",
        "files",
        "parallelisable"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parallelisable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "subagent_split": {
      "type": "object",
      "required": [
        "title",
        "files"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
